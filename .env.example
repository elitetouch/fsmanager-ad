# Base URL of the FSManager Laravel API.
# In development this is typically http://localhost:8000.
# In production point this at the deployed API (e.g. https://api.fsinnovation.net).
# Do NOT include the trailing /api/v1 — the client appends it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Display name shown in the browser tab + sidebar. Override per environment.
NEXT_PUBLIC_BRAND_NAME=FSManager Admin

# How long, in minutes, to assume a logged-in session is valid before forcing
# a refresh. Sanctum tokens themselves are server-controlled; this is purely
# a client UX hint.
NEXT_PUBLIC_SESSION_HINT_MINUTES=120
